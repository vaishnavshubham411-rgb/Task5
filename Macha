<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Two Leaves and a Bud | Organic Tea</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #2a2857;
    --cream: #f5f0e8;
    --warm-white: #faf8f4;
    --green: #4a7c59;
    --green-light: #7aaa8a;
    --gold: #c8a96e;
    --dark: #1a1a2e;
    --text: #2c2c2c;
    --text-muted: #6b6b6b;
    --border: #e8e2d9;
    --font-serif: 'Playfair Display', serif;
    --font-body: 'DM Sans', sans-serif;
    --font-display: 'Cormorant Garamond', serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    color: var(--text);
    background: var(--warm-white);
    overflow-x: hidden;
  }

  a { text-decoration: none; color: inherit; }
  ul { list-style: none; }
  img { max-width: 100%; display: block; }

  /* ─── ANNOUNCEMENT BAR ─── */
  .announcement-bar {
    background: var(--navy);
    color: #fff;
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    letter-spacing: 0.04em;
    font-weight: 400;
  }

  /* ─── HEADER ─── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--warm-white);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 32px;
    height: 72px;
  }

  .nav-left { display: flex; gap: 28px; align-items: center; }
  .nav-left a {
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text);
    transition: color 0.2s;
    position: relative;
  }
  .nav-left a:hover { color: var(--navy); }

  .logo {
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo svg { height: 38px; width: auto; }
  .logo-text {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .nav-right {
    display: flex;
    gap: 20px;
    align-items: center;
    justify-content: flex-end;
  }
  .nav-right a {
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text);
    transition: color 0.2s;
  }
  .nav-right a:hover { color: var(--navy); }

  .cart-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--navy);
    color: #fff !important;
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 13px !important;
    font-weight: 500 !important;
  }

  /* Mega Menu */
  .nav-item { position: relative; }
  .nav-item > a { cursor: pointer; }
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 32px;
    width: 560px;
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    margin-top: 8px;
  }
  .nav-item:hover .mega-menu { display: grid; }
  .mega-col h4 {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .mega-col a {
    display: block;
    font-size: 14px;
    font-weight: 400;
    padding: 5px 0;
    color: var(--text);
    transition: color 0.2s;
  }
  .mega-col a:hover { color: var(--navy); }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, #2a4a3a 0%, #1e3a2e 40%, #2a2857 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(74,124,89,0.3) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(42,40,87,0.5) 0%, transparent 60%),
      radial-gradient(ellipse at 50% 90%, rgba(200,169,110,0.15) 0%, transparent 50%);
  }

  /* Decorative leaf shapes */
  .hero-leaves {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-leaf {
    position: absolute;
    opacity: 0.12;
  }
  .hero-leaf svg { fill: #7aaa8a; }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 40px 20px;
    max-width: 900px;
  }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 28px;
    font-weight: 500;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(52px, 8vw, 96px);
    font-weight: 400;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    max-width: 540px;
    margin: 0 auto 40px;
    font-weight: 300;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    color: var(--navy);
    padding: 16px 36px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
  }

  .hero-scroll {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.5);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    animation: bounce 2s ease-in-out infinite;
  }
  .hero-scroll span { writing-mode: vertical-rl; }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.3);
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ─── TAGLINE BAND ─── */
  .tagline-section {
    padding: 80px 32px;
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .tagline-section h2 {
    font-family: var(--font-serif);
    font-size: clamp(30px, 4vw, 50px);
    font-weight: 400;
    line-height: 1.3;
    color: var(--navy);
  }

  .tagline-section h2 em {
    font-style: italic;
    color: var(--green);
  }

  /* ─── PRODUCTS ─── */
  .section {
    padding: 64px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 36px;
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(26px, 3vw, 38px);
    font-weight: 400;
    color: var(--navy);
    line-height: 1.2;
  }

  .section-title em { font-style: italic; color: var(--green); }

  .view-all {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--navy);
    border-bottom: 1px solid var(--navy);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .view-all:hover { color: var(--green); border-color: var(--green); }

  /* Product Grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 28px;
  }

  .product-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    cursor: pointer;
    border: 1px solid var(--border);
  }
  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
  }

  .product-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 13px;
    color: var(--text-muted);
    font-style: italic;
  }

  .product-img-placeholder {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
  }

  .product-info { padding: 18px 20px 22px; }

  .product-category {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
    font-weight: 600;
  }

  .product-name {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .product-desc {
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .product-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .product-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }

  .product-stars {
    font-size: 11px;
    color: var(--gold);
    display: flex;
    gap: 1px;
    align-items: center;
  }
  .product-rating-count { color: var(--text-muted); font-size: 11px; margin-left: 4px; }

  .add-btn {
    background: var(--navy);
    color: #fff;
    border: none;
    border-radius: 100px;
    padding: 8px 16px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.2s, transform 0.15s;
  }
  .add-btn:hover { background: var(--green); transform: scale(1.04); }

  /* ─── DISCOVER / FILTER ─── */
  .discover-section {
    background: var(--navy);
    padding: 72px 32px;
    text-align: center;
    color: #fff;
  }

  .discover-inner { max-width: 900px; margin: 0 auto; }

  .discover-section .section-label { color: rgba(255,255,255,0.5); }

  .discover-section .section-title {
    color: #fff;
    margin-bottom: 40px;
  }
  .discover-section .section-title em { color: var(--gold); }

  .filter-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .filter-chip {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 9px 20px;
    border-radius: 100px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 400;
  }
  .filter-chip:hover, .filter-chip.active {
    background: #fff;
    color: var(--navy);
    border-color: #fff;
  }

  /* ─── ORIGIN SECTION ─── */
  .origin-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
    overflow: hidden;
  }

  .origin-content {
    background: var(--cream);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 64px;
  }

  .origin-content .section-label { color: var(--text-muted); margin-bottom: 12px; }

  .origin-content h2 {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 400;
    color: var(--navy);
    line-height: 1.1;
    margin-bottom: 24px;
    text-transform: lowercase;
  }

  .origin-content p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 36px;
    max-width: 440px;
  }

  .origin-pillars {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
  }

  .pillar {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 14px;
    font-weight: 500;
    color: var(--navy);
  }

  .pillar-icon {
    width: 40px;
    height: 40px;
    background: var(--navy);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .origin-image {
    position: relative;
    overflow: hidden;
  }

  .origin-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .origin-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2a4a3a, #1e3a2e, #4a7c59);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 120px;
    min-height: 560px;
  }

  /* ─── REVIEWS ─── */
  .reviews-section {
    padding: 80px 32px;
    background: var(--warm-white);
  }

  .reviews-inner { max-width: 1200px; margin: 0 auto; }

  .reviews-section .section-label { text-align: center; }
  .reviews-section .section-title {
    text-align: center;
    margin-bottom: 52px;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }

  .review-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .review-stars { color: var(--gold); font-size: 14px; }

  .review-text {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text);
    flex: 1;
    font-style: italic;
    font-family: var(--font-display);
    font-size: 16px;
  }

  .review-product {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  .review-product-img {
    width: 40px;
    height: 40px;
    background: var(--cream);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .review-product-info { flex: 1; }
  .review-product-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.3;
  }
  .review-author {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* ─── WHOLESALE BANNER ─── */
  .wholesale-section {
    background: var(--green);
    padding: 80px 32px;
    text-align: center;
    color: #fff;
  }

  .wholesale-inner { max-width: 700px; margin: 0 auto; }

  .wholesale-section h2 {
    font-family: var(--font-serif);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .wholesale-section h2 em { font-style: italic; color: rgba(255,255,255,0.75); }

  .wholesale-section p {
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 2px solid #fff;
    color: #fff;
    padding: 14px 36px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: all 0.2s;
  }
  .btn-outline-white:hover {
    background: #fff;
    color: var(--green);
  }

  /* ─── LATTES ─── */
  .lattes-section {
    padding: 80px 32px;
    background: var(--cream);
  }

  .lattes-inner { max-width: 1400px; margin: 0 auto; }

  .lattes-header { text-align: center; margin-bottom: 52px; }
  .lattes-subtitle {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .lattes-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }

  .latte-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform 0.3s;
    cursor: pointer;
  }
  .latte-card:hover { transform: translateY(-4px); }

  .latte-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
  }

  .latte-info { padding: 20px; }

  .latte-brand {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .latte-name {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .latte-desc {
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.55;
    margin-bottom: 16px;
  }

  .shop-link {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--navy);
    border-bottom: 1px solid var(--navy);
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .shop-link:hover { color: var(--green); border-color: var(--green); }

  /* ─── JOURNAL ─── */
  .journal-section {
    padding: 80px 32px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .journal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .journal-card {
    cursor: pointer;
    transition: transform 0.3s;
  }
  .journal-card:hover { transform: translateY(-4px); }

  .journal-img {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 14px;
    object-fit: cover;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    overflow: hidden;
  }

  .journal-category {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .journal-title {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--navy);
    line-height: 1.35;
  }

  /* ─── CLOSING CTA ─── */
  .closing-cta {
    background: var(--navy);
    padding: 100px 32px;
    text-align: center;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .closing-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 60%, rgba(74,124,89,0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 30%, rgba(200,169,110,0.1) 0%, transparent 50%);
  }

  .closing-cta-inner { position: relative; max-width: 700px; margin: 0 auto; }

  .closing-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(38px, 5vw, 68px);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 28px;
  }
  .closing-cta h2 em { font-style: italic; color: var(--gold); }

  .closing-cta p {
    font-size: 16px;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  /* ─── NEWSLETTER ─── */
  .newsletter-section {
    background: var(--cream);
    padding: 72px 32px;
    text-align: center;
  }

  .newsletter-inner { max-width: 520px; margin: 0 auto; }

  .newsletter-label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .newsletter-inner h3 {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .newsletter-inner p {
